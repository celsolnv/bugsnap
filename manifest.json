{
  "manifest_version": 3,
  "name": "BugSnap - Bug Reporter",
  "version": "1.0.0",
  "description": "Captura bugs com screenshot, console logs e info do sistema em um clique.",
  "permissions": [
    "activeTab",
    "tabs",
    "debugger",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png"
    }
  },
  "background": {
    "service_worker": "core/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "core/content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "core/page-debug.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png"
  }
}
